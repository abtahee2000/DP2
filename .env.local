# GEMINI_API_KEY: Your Gemini API key for accessing Google's generative AI models.
# Get your API key from https://ai.google/
# Leave as placeholder or replace with your actual key for AI features
# The app will work in demo mode without a valid key
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: For local development, leave as localhost
# When deploying, set this to your domain
APP_URL="http://localhost:3000"